   "source": [
    "'''\n",
    "#1330 두 정수 A와 B가 주어졌을 때, A와 B를 비교하는 프로그램을 작성하시오.\n",
    "'''\n",
    "\n",
    "answer = input(\"\")\n",
    "\n",
    "A, B = answer.split()\n",
    "\n",
    "# 분리된 문자열을 정수로 변환\n",
    "A= int(A)\n",
    "B = int(B)\n",
    "\n",
    "if A > B:\n",
    "    print(\">\")\n",
    "elif A < B :\n",
    "    print(\"<\")\n",
    "else:\n",
    "    print(\"==\")"
   ]
